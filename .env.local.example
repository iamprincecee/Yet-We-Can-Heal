# Copy this file to .env.local and fill in your real values.
# Get these from your Supabase project: Settings -> API

# Safe to expose in the browser (protected by Row Level Security)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVER-ONLY -- never expose this in the browser or commit it to git.
# Used only to invite/remove team member accounts (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
